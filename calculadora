import java.util.Scanner;
public class CalculadoraProcedimientos {

 public static void menu() {
 System.out.println("Ingrese una operación:");
 System.out.println("1- Suma");
 System.out.println("2- Resta");
 System.out.println("3- Multiplicación");
 System.out.println("4- División");
 }
 public static void suma(int num1, int num2) {
 int resultado = num1 + num2;
 System.out.println("El resultado de la suma es: " + resultado);
 }
 public static void resta(int num1, int num2) {
 int resultado = num1 - num2;
 System.out.println("El resultado de la resta es: " + resultado);
 }

 public static void multiplicacion(int num1, int num2) {
 int resultado = num1 * num2;
 System.out.println("El resultado de la multiplicación es: " + resultado);
 }
 public static void division(int num1, int num2) {
 if (num2 == 0) {
 System.out.println("No se puede dividir por 0.");
 return;
 }
 double resultado = (double) num1 / num2;
 System.out.println("El resultado de la división es: " + resultado);
 }
 public static void main(String[] args) {
 Scanner scanner = new Scanner(System.in);
 int operacion, num1, num2;
 menu();
 operacion = scanner.nextInt();
 while (operacion < 1 || operacion > 4) {
 System.out.println("Operación inválida, ingrese otra opción:");
 operacion = scanner.nextInt();
 }

 System.out.println("Ingrese el primer número:");
 num1 = scanner.nextInt();

 System.out.println("Ingrese el segundo número:");
 num2 = scanner.nextInt();
 if (operacion == 4) {
 while (num2 == 0) {
 System.out.println("No se permiten divisiones por 0, ingrese otro
número:");
 num2 = scanner.nextInt();
 }
 }
 switch (operacion) {
 case 1 -> suma(num1, num2);
 case 2 -> resta(num1, num2);
 case 3 -> multiplicacion(num1, num2);
 case 4 -> division(num1, num2);
 }
 scanner.close();
 }
}
