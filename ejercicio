# PRUEBA DEL PROGRAMA
# -----------------------------

# Crear cuenta
cuenta = Cuenta("sofia", "sofia@gmail.com", "imap.gmail.com", "smtp.gmail.com")

# Crear cliente de correo
cliente = ClienteCorreo(cuenta)

# Crear contactos
c1 = Contacto("Juan", "Perez", "juan@gmail.com")
c2 = Contacto("Ana", "Lopez", "ana@gmail.com")

cliente.agregar_contacto(c1)
cliente.agregar_contacto(c2)

# Crear correos
correo1 = Correo("Hola", "¿Cómo estás?", "juan@gmail.com", ["sofia@gmail.com"])
correo2 = Correo("Trabajo", "Entrega mañana", "ana@gmail.com", ["sofia@gmail.com"])

# Simular recepción
cliente.agregar_correo_recibido(correo1)
cliente.agregar_correo_recibido(correo2)

# Simular envío
correo3 = Correo("Re: Hola", "Todo bien!", "sofia@gmail.com", ["juan@gmail.com"])
cliente.enviar_correo(correo3)

# Mostrar resultados
print("Total correos:", cliente.cantidad_correos())
print("Recibidos:", cliente.cantidad_recibidos())
print("Enviados:", cliente.cantidad_enviados())
print("No leídos:", cliente.cantidad_no_leidos())
print("Contactos:", cliente.cantidad_contactos())