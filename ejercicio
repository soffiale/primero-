# Clase Correo
class Correo:
    def __init__(self, asunto, mensaje, remitente, destinatarios):
        self.asunto = asunto
        self.mensaje = mensaje
        self.remitente = remitente
        self.destinatarios = destinatarios  # lista
        self.leido = False  # por defecto no leído


# Clase Contacto
class Contacto:
    def __init__(self, nombre, apellido, email):
        self.nombre = nombre
        self.apellido = apellido
        self.email = email


# Clase Cuenta
class Cuenta:
    def __init__(self, usuario, direccion_mail, servidor_entrada, servidor_salida):
        self.usuario = usuario
        self.direccion_mail = direccion_mail
        self.servidor_entrada = servidor_entrada
        self.servidor_salida = servidor_salida


# Clase principal ClienteCorreo
class ClienteCorreo:
    def __init__(self, cuenta):
        self.cuenta = cuenta
        self.contactos = []
        self.recibidos = []
        self.enviados = []

    # Funcionalidades

    def cantidad_correos(self):
        return len(self.recibidos) + len(self.enviados)

    def cantidad_recibidos(self):
        return len(self.recibidos)

    def cantidad_enviados(self):
        return len(self.enviados)

    def cantidad_no_leidos(self):
        contador = 0
        for correo in self.recibidos:
            if not correo.leido:
                contador += 1
        return contador

    def cantidad_contactos(self):
        return len(self.contactos)

    def agregar_correo_recibido(self, correo):
        self.recibidos.append(correo)

    def enviar_correo(self, correo):
        self.enviados.append(correo)

    def agregar_contacto(self, contacto):
        self.contactos.append(contacto)


